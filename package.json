{
  "name": "@bahmni/form2-controls",
  "version": "0.0.3",
  "description": "Repository for form controls",
  "license": "MPL-2.0",
  "main": "./dist/bundle.js",
  "style": "./dist/bundle.css",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rimraf dist/*",
    "build": "webpack && copyfiles index.d.ts dist",
    "build-dev": "webpack --config webpack.dev.config.js",
    "pretest": "rimraf coverage/*",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --watchAll=false",
    "posttest": "eslint --ext .js --ext .jsx ./src ./test",
    "lint": "eslint --ext .js --ext .jsx ./src ./test",
    "lint:fix": "eslint --ext .js --ext .jsx ./src ./test --fix",
    "publish": "npm publish || true",
    "ci": "yarn run clean && yarn run build && yarn run publish",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "bump-up": "npm version patch -m 'Bumped to version %s'",
    "watch": "webpack --watch --config webpack.dev.config.js"
  },
  "author": "bahmni@thoughtworks.com",
  "peerDependencies": {
    "@bahmni/design-system": ">=0.0.1-dev.215",
